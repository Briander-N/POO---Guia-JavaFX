<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700.0"
            prefWidth="1000.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.tareaguiajavafx.crudController">
    <children>

        <Label layoutX="20.0" layoutY="20.0" style="-fx-font-size:18px; -fx-font-weight:bold;" text="Registro de Participantes" />

        <Label layoutX="20.0" layoutY="70.0" text="Cédula:" />
        <TextField fx:id="txtCedula" layoutX="120.0" layoutY="65.0" prefWidth="200.0" />

        <Label layoutX="20.0" layoutY="110.0" text="Nombre:" />
        <TextField fx:id="txtNombre" layoutX="120.0" layoutY="105.0" prefWidth="200.0" />

        <Label layoutX="20.0" layoutY="150.0" text="Apellido:" />
        <TextField fx:id="txtApellido" layoutX="120.0" layoutY="145.0" prefWidth="200.0" />

        <Label layoutX="20.0" layoutY="190.0" text="Edad:" />
        <TextField fx:id="txtEdad" layoutX="120.0" layoutY="185.0" prefWidth="200.0" />

        <Label layoutX="20.0" layoutY="230.0" text="Correo:" />
        <TextField fx:id="txtCorreo" layoutX="120.0" layoutY="225.0" prefWidth="200.0" />

        <Label layoutX="20.0" layoutY="270.0" text="Estado Civil:" />
        <ComboBox fx:id="cbEstadoCivil" layoutX="120.0" layoutY="265.0" prefWidth="200.0" />

        <Label layoutX="20.0" layoutY="310.0" text="Jornada:" />

        <RadioButton fx:id="rbMatutina" layoutX="120.0" layoutY="310.0" text="Matutina" />

        <RadioButton fx:id="rbVespertina" layoutX="220.0" layoutY="310.0" text="Vespertina" />

        <RadioButton fx:id="rbNocturna" layoutX="340.0" layoutY="310.0" text="Nocturna" />

        <Label layoutX="20.0" layoutY="350.0" text="Categoría:" />
        <ComboBox fx:id="cbCategoria" layoutX="120.0" layoutY="345.0" prefWidth="200.0" />

        <Label layoutX="20.0" layoutY="390.0" text="Observaciones:" />
        <TextArea fx:id="txtObservaciones" layoutX="120.0" layoutY="390.0" prefHeight="80.0" prefWidth="250.0" />

        <Button fx:id="btnGuardar" layoutX="420.0" layoutY="70.0" text="Guardar" />

        <Button fx:id="btnActualizar" layoutX="420.0" layoutY="110.0" text="Actualizar" />

        <Button fx:id="btnEliminar" layoutX="420.0" layoutY="150.0" text="Eliminar" />

        <Button fx:id="btnLimpiar" layoutX="420.0" layoutY="190.0" text="Limpiar" />

        <TableView fx:id="tblParticipantes" layoutX="20.0" layoutY="500.0" prefHeight="180.0" prefWidth="983.0">

            <columns>

                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colCedula" prefWidth="100.0" text="Cédula" />
                <TableColumn fx:id="colNombre" prefWidth="120.0" text="Nombre" />
                <TableColumn fx:id="colApellido" prefWidth="120.0" text="Apellido" />
                <TableColumn fx:id="colEdad" prefWidth="60.0" text="Edad" />
                <TableColumn fx:id="colCorreo" prefWidth="180.0" text="Correo" />
                <TableColumn fx:id="colEstadoCivil" prefWidth="120.0" text="Estado Civil" />
                <TableColumn fx:id="colJornada" prefWidth="120.0" text="Jornada" />
                <TableColumn fx:id="colCategoria" prefWidth="120.0" text="Categoría" />

            </columns>

        </TableView>

    </children>

</AnchorPane>
